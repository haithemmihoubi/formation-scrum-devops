{
  "info": {
    "name": "QuickBite API — Formation (Agile/DevOps/Spring Security)",
    "description": "Collection complète de l'API fil rouge QuickBite. Le login enregistre automatiquement accessToken et refreshToken dans les variables de collection. Utilisateurs de test : admin/admin123 (ADMIN), client/client123 (CLIENT).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "0 — Health (public)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "0.5 — Register (signup)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('201 Created', () => pm.response.code === 201 || pm.response.code === 409);",
              "if (pm.response.code === 201) {",
              "  const b = pm.response.json();",
              "  pm.collectionVariables.set('accessToken', b.accessToken);",
              "  pm.collectionVariables.set('refreshToken', b.refreshToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"nouveau\",\n  \"password\": \"secret123\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
      }
    },
    {
      "name": "1 — Login ADMIN",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.code === 200);",
              "const b = pm.response.json();",
              "pm.collectionVariables.set('accessToken', b.accessToken);",
              "pm.collectionVariables.set('refreshToken', b.refreshToken);",
              "console.log('Tokens admin enregistrés');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
      }
    },
    {
      "name": "2 — Login CLIENT",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.code === 200);",
              "const b = pm.response.json();",
              "pm.collectionVariables.set('accessToken', b.accessToken);",
              "pm.collectionVariables.set('refreshToken', b.refreshToken);",
              "console.log('Tokens client enregistrés');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"client\",\n  \"password\": \"client123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
      }
    },
    {
      "name": "3 — Mon profil (/auth/me)",
      "request": {
        "method": "GET",
        "header": [],
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
        "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
      }
    },
    {
      "name": "4 — Rafraîchir le token (/auth/refresh)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.code === 200);",
              "const b = pm.response.json();",
              "pm.collectionVariables.set('accessToken', b.accessToken);",
              "pm.collectionVariables.set('refreshToken', b.refreshToken);",
              "console.log('Token rafraîchi (rotation)');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
      }
    },
    {
      "name": "5 — Lister mes commandes (GET /orders)",
      "request": {
        "method": "GET",
        "header": [],
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
        "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
      }
    },
    {
      "name": "6 — Créer une commande (POST /orders)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"item\": \"Tacos Poulet\",\n  \"price\": 7.5\n}"
        },
        "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
      }
    },
    {
      "name": "7 — Supprimer une commande (DELETE /orders/:id) — ADMIN",
      "request": {
        "method": "DELETE",
        "header": [],
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
        "url": {
          "raw": "{{baseUrl}}/orders/1",
          "host": ["{{baseUrl}}"],
          "path": ["orders", "1"]
        }
      }
    },
    {
      "name": "8 — Console admin (GET /admin/users) — ADMIN",
      "request": {
        "method": "GET",
        "header": [],
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
        "url": { "raw": "{{baseUrl}}/admin/users", "host": ["{{baseUrl}}"], "path": ["admin", "users"] }
      }
    }
  ]
}
