{
  "info": {
    "name": "QuickBite — Keycloak (enterprise)",
    "description": "API QuickBite sécurisée par Keycloak via une façade d'authentification.\nFlux : Register -> Login -> (appels protégés) -> Refresh -> Logout.\nLe login/refresh enregistrent automatiquement les tokens dans les variables.\nbaseUrl pointe sur l'API (http://localhost:8082) : tout passe par la façade, aucun accès direct à Keycloak requis.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8082" },
    { "key": "username", "value": "sarah" },
    { "key": "email", "value": "sarah@quickbite.local" },
    { "key": "password", "value": "secret123" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "0 — Health (public)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "1 — Register (signup)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('201 Created', () => pm.response.code === 201 || pm.response.code === 409);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"firstName\": \"Sarah\",\n  \"lastName\": \"K\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
      }
    },
    {
      "name": "2 — Login",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('200 OK', () => pm.response.code === 200);",
          "const b = pm.response.json();",
          "pm.collectionVariables.set('accessToken', b.access_token);",
          "pm.collectionVariables.set('refreshToken', b.refresh_token);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
      }
    },
    {
      "name": "3 — Login ADMIN",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "const b = pm.response.json();",
          "pm.collectionVariables.set('accessToken', b.access_token);",
          "pm.collectionVariables.set('refreshToken', b.refresh_token);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
      }
    },
    {
      "name": "4 — Mon profil (/me)",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
        "url": { "raw": "{{baseUrl}}/me", "host": ["{{baseUrl}}"], "path": ["me"] }
      }
    },
    {
      "name": "5 — Lister mes commandes",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
        "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
      }
    },
    {
      "name": "6 — Créer une commande",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
        "body": { "mode": "raw", "raw": "{\n  \"item\": \"Sushi\",\n  \"price\": 12.0\n}" },
        "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
      }
    },
    {
      "name": "7 — Refresh token",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('200 OK', () => pm.response.code === 200);",
          "const b = pm.response.json();",
          "pm.collectionVariables.set('accessToken', b.access_token);",
          "pm.collectionVariables.set('refreshToken', b.refresh_token);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
      }
    },
    {
      "name": "8 — Console admin (/admin/summary)",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
        "url": { "raw": "{{baseUrl}}/admin/summary", "host": ["{{baseUrl}}"], "path": ["admin", "summary"] }
      }
    },
    {
      "name": "9 — Logout",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
      }
    }
  ]
}
